JWT_SECRET=cambia-esto-por-una-clave-segura-en-produccion

# Credenciales del único usuario admin (se crea automáticamente al iniciar el servidor)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Base de datos Turso (https://app.turso.tech)
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=

# Dominios de producción separados por coma (sin espacios al inicio/fin)
# Ejemplo: https://mi-app.vercel.app,https://mi-dominio.com
ALLOWED_ORIGINS=
